# NEVER commit .env to Git

# App
DEBUG=True
APP_NAME=SignAI

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Database 
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/signai

# Redis
REDIS_URL=redis://localhost:6379

# ML Model path (relative to backend/)
MODEL_PATH=../ml_training/saved_models/sign_model_v1.h5
CONFIDENCE_THRESHOLD=0.70

# Translation API 
GOOGLE_TRANSLATE_API_KEY=
